<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CollectionView_Samples.Views.Headers2View"
             Title="Headers2View">
    <VerticalStackLayout>
        <Grid BackgroundColor="Green">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Text="AA" FontSize="18" FontAttributes="Bold" Margin="5,0" />
            <Label Grid.Column="1" Text="BB" FontSize="18" FontAttributes="Bold" Margin="5,0" />
            <Label Grid.Column="2" Text="CC" FontSize="18" FontAttributes="Bold"  />
        </Grid>
        <CollectionView ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid BackgroundColor="Orange">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding IsSelected}" />
                        <HorizontalStackLayout Grid.Column="2" Margin="0,10">
                            <Label Text="{Binding Title}" FontAttributes="Bold"/>
                            <Label Text="{Binding Description}" Margin="10,0,0,0" LineBreakMode="TailTruncation" />
                        </HorizontalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>